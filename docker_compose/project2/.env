# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ────────────────────────────────────────
MONGO_URI=mongodb://chat_mongo:27017/chatdb

# ─── RabbitMQ ───────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@chat_rabbitmq:5672

# ─── JWT / Auth ─────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=7d
